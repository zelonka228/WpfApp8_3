<Window x:Class="WpfApp8_3.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <TextBlock Text="Доходы" Margin="100,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <ListBox x:Name="incomeList" Width="300" Height="200" Margin="50,40,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>


        <TextBlock Text="Расходы" Margin="500,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <ListBox x:Name="expenseList" Width="300" Height="200" Margin="450,40,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <TextBlock Text="Сумма" Margin="60,270,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBox x:Name="amountInput" Width="120" Height="25" Margin="60,290,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        
        <TextBlock Text="Описание" Margin="220,270,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBox x:Name="descriptionInput" Width="150" Height="25" Margin="220,290,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <ComboBox x:Name="typeBox" Width="120" Margin="400,290,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
            <ComboBoxItem Content="Доход"/>
            <ComboBoxItem Content="Расход"/>
        </ComboBox>
        
        <Button Content="Добавить" Width="100" Height="30" Margin="550,285,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="Add_Click"/>
        <Button Content="Статистика" Width="120" Height="30" Margin="660,285,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="OpenWindow_Click"/>

    </Grid>
</Window>